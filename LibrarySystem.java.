class LIBRARYmember{

    private int memberId;
    private String memberName;
    private int booksIssued;

    ArrayList<bookDetails> borrowedBooks = new ArrayList<>();

    public LIBRARYmember(int memberId, String memberName, int booksIssued) {
        this.memberId = memberId;
        this.memberName = memberName;

        if (booksIssued >= 0) {
            this.booksIssued = booksIssued;
        }
    }

    public void setMemberId(int memberId) {
        this.memberId = memberId;
    }

    public int getMemberId() {
        return memberId;
    }

    public void setMemberName(String memberName) {
        this.memberName = memberName;
    }

    public String getMemberName() {
        return memberName;
    }

    public void setBooksIssued(int booksIssued) {
        if (booksIssued >= 0) {
            this.booksIssued = booksIssued;
        }
    }

    public int getBooksIssued() {
        return booksIssued;
    }

    public void displayDetails() {
        System.out.println("Member ID: " + memberId);
        System.out.println("Member Name: " + memberName);
        System.out.println("Books Issued: " + booksIssued);
        System.out.println("                                  ");
    }

    public void displayBorrowedBooks(){
        for(bookDetails b : borrowedBooks){
            System.out.println(b.getTitle());
        }
    }
}


class bookDetails {

    String author;
    String title;
    int pageNumber;

    public bookDetails(String author, String title, int pageNumber) {
        this.author = author;
        this.title = title;
        this.pageNumber = pageNumber;
    }

    public String getAuthor() {
        return author;
    }

    public String getTitle() {
        return title;
    }

    public int getPageNumber() {
        return pageNumber;
    }

    public void setAuthor(String author) {
        this.author = author;
    }

    public void setPageNumber(int pageNumber) {
        this.pageNumber = pageNumber;
    }

    public void setTitle(String title) {
        this.title = title;
    }
}


class Library {

    ArrayList<bookDetails> books = new ArrayList<>();

    public void addBook(bookDetails book){
        books.add(book);
    }

    public void borrowBook(LIBRARYmember member, bookDetails book){
        member.borrowedBooks.add(book);
        member.setBooksIssued(member.getBooksIssued() + 1);
    }

    public void returnBook(LIBRARYmember member, bookDetails book){
        if(member.borrowedBooks.contains(book )) {
            member.borrowedBooks.remove(book);
        member.setBooksIssued(member.getBooksIssued() - 1);
        }
    }
}
